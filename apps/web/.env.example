# =============================================================================
# WEB APPLICATION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in the values
# Never commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
# Options: development, staging, production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Application URL
# -----------------------------------------------------------------------------
# The public URL where your app is hosted
# NEXT_PUBLIC_APP_URL=https://your-app.com

# -----------------------------------------------------------------------------
# Smart Contract Addresses (REQUIRED)
# -----------------------------------------------------------------------------
# Hospital Network Token contract address on Celo Mainnet
# Format: 0x followed by 40 hexadecimal characters
NEXT_PUBLIC_HOSPITAL_TOKEN_ADDRESS=0x209c0138c80C60a570333D03b980e1cA22880fE1

# -----------------------------------------------------------------------------
# RPC URLs
# -----------------------------------------------------------------------------
# Celo Mainnet RPC endpoint
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Celo Sepolia Testnet RPC endpoint (for testing)
NEXT_PUBLIC_CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org/

# -----------------------------------------------------------------------------
# Chain IDs
# -----------------------------------------------------------------------------
# Celo Mainnet chain ID
NEXT_PUBLIC_CELO_CHAIN_ID=42220

# Celo Sepolia Testnet chain ID
NEXT_PUBLIC_CELO_SEPOLIA_CHAIN_ID=11142220

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable testnet support (true/false)
NEXT_PUBLIC_ENABLE_TESTNET=false

# -----------------------------------------------------------------------------
# Monitoring & Analytics (OPTIONAL)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
# Get this from: https://sentry.io/settings/projects/your-project/keys/
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Analytics tracking ID (e.g., Google Analytics)
# NEXT_PUBLIC_ANALYTICS_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Server-Side Only (DO NOT prefix with NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
# Sentry auth token for source maps upload
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. Never commit .env.local or any file containing real values
# 2. NEXT_PUBLIC_ prefix exposes variables to the browser - use carefully
# 3. Keep private keys and sensitive data in server-side variables only
# 4. Rotate credentials regularly
# 5. Use different values for development, staging, and production
# =============================================================================
