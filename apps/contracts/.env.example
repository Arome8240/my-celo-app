# =============================================================================
# SMART CONTRACTS ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in the values
# Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Private Key (REQUIRED for deployments and transactions)
# -----------------------------------------------------------------------------
# Your wallet private key (with or without 0x prefix)
# ⚠️  CRITICAL: Never share or commit this value!
# ⚠️  Use a dedicated wallet for deployments, not your main wallet
# ⚠️  For production, use hardware wallet or secure key management
PRIVATE_KEY=your_private_key_here

# -----------------------------------------------------------------------------
# Contract Addresses
# -----------------------------------------------------------------------------
# Hospital Network Token contract address (after deployment)
TOKEN_ADDRESS=0x209c0138c80C60a570333D03b980e1cA22880fE1

# -----------------------------------------------------------------------------
# RPC URLs
# -----------------------------------------------------------------------------
# Celo Mainnet RPC endpoint
CELO_RPC_URL=https://forno.celo.org

# Celo Sepolia Testnet RPC endpoint
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org/

# -----------------------------------------------------------------------------
# Block Explorer API Keys (OPTIONAL)
# -----------------------------------------------------------------------------
# Etherscan API key for contract verification
# Get from: https://celoscan.io/myapikey
# ETHERSCAN_API_KEY=your_etherscan_api_key

# -----------------------------------------------------------------------------
# Gas Reporting (OPTIONAL)
# -----------------------------------------------------------------------------
# Enable gas usage reporting in tests (true/false)
# REPORT_GAS=true

# -----------------------------------------------------------------------------
# Transaction Generation (for generate-transfers script)
# -----------------------------------------------------------------------------
# Recipient address for token transfers (optional, defaults to sender)
# RECIPIENT_ADDRESS=0x...

# Number of transactions to generate
TX_COUNT=1000

# Amount per transaction (in tokens)
AMOUNT=0.000001

# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
# Before deploying to mainnet:
# 1. ✅ Test deployment on testnet (Celo Sepolia)
# 2. ✅ Verify contract on block explorer
# 3. ✅ Test all contract functions
# 4. ✅ Audit contract code
# 5. ✅ Use hardware wallet or secure key management
# 6. ✅ Have sufficient CELO for gas fees
# 7. ✅ Backup private key securely
# 8. ✅ Document contract address
# =============================================================================

# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================
# 1. Never commit .env file to version control
# 2. Use different private keys for testnet and mainnet
# 3. Keep private keys in secure key management system (production)
# 4. Rotate private keys regularly
# 5. Use hardware wallets for high-value operations
# 6. Monitor wallet for unauthorized transactions
# 7. Keep minimal funds in deployment wallet
# 8. Use multi-sig for production deployments
# =============================================================================

# =============================================================================
# NETWORK INFORMATION
# =============================================================================
# Celo Mainnet:
#   - Chain ID: 42220
#   - RPC: https://forno.celo.org
#   - Explorer: https://celoscan.io
#   - Currency: CELO
#
# Celo Sepolia Testnet:
#   - Chain ID: 11142220
#   - RPC: https://forno.celo-sepolia.celo-testnet.org/
#   - Explorer: https://sepolia.celoscan.io
#   - Faucet: https://faucet.celo.org/sepolia
# =============================================================================
